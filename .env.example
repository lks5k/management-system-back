# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=imsas_dev
POSTGRES_USER=imsas_user
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@imsas.local
PGADMIN_PASSWORD=cambia_esta_clave
PGADMIN_PORT=5050

# Spring Boot (se usa en application.yml)
JWT_SECRET=cambia_este_secreto_base64_minimo_256bits
JWT_EXPIRATION_MS=86400000
